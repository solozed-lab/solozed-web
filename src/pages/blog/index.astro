---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import BlogNav from '../../components/BlogNav.astro';
import OrbBackground from '../../components/react/OrbBackground';
import ShinyText from '../../components/react/ShinyText';
import Footer from '../../components/Footer.astro';
import { getTagColor } from '../../utils/tagColors';
import { readingTime } from '../../utils/readingTime';
import '../../styles/global.css';
import '../../styles/tokens.css';

const siteUrl = Astro.site?.toString() ?? '';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) =>
  b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const allTags = [...new Set(sortedPosts.flatMap(post => post.data.tags))];

const blogSchema = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "solozed Blog",
  "description": "在AI时代，solozed探索技术与生活的从容之道。",
  "url": `${siteUrl}/blog`,
  "inLanguage": "zh-CN",
  "publisher": {
    "@type": "Organization",
    "name": "solozed",
    "url": siteUrl
  }
};
---

<Layout
  title="Blog - Solozed | AI时代，值得更加从容"
  description="在AI时代，solozed探索技术与生活的从容之道。每篇文章都是一次关于初心、技术与生活的深度思考。"
  pathname="/blog"
>
  <Fragment slot="head">
    <meta property="og:image" content={`${siteUrl}/og-default.svg`} />
    <meta name="twitter:image" content={`${siteUrl}/og-default.svg`} />
    <script type="application/ld+json" set:html={JSON.stringify(blogSchema)} />
  </Fragment>

  <OrbBackground client:idle />
  <BlogNav currentPath="/blog" theme="light" />

  <main class="main">
    <header class="header">
      <h1 class="header-title">
        <ShinyText text="The Age of AI, the grace to be" speed={5} color="#1E293B" shineColor="#38D9D9" client:idle />
      </h1>
    </header>

    <div class="search-filter" role="search">
      <div class="tag-filters" role="group" aria-label="Filter by tag">
        <button class="tag-filter-btn active" data-tag="all">All</button>
        {allTags.map(tag => (
          <button class="tag-filter-btn" data-tag={tag}>{tag}</button>
        ))}
      </div>
      <div class="search-box">
        <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"/>
          <path d="M21 21l-4.35-4.35"/>
        </svg>
        <input type="text" class="search-input" placeholder="Search articles..." id="searchInput" />
      </div>
    </div>

    <div class="card-grid" id="cardGrid">
      {sortedPosts.map((post, index) => (
        <article class="card" data-tags={JSON.stringify(post.data.tags)} style={`animation-delay: ${0.4 + index * 0.1}s`}>
          <div class="card-meta">
            <time class="card-date">{post.data.pubDate.toISOString().split('T')[0]}</time>
            <span class="card-dot"></span>
            <span class="card-reading-time">{readingTime(post.body)} min read</span>
          </div>
          <h2 class="card-title">
            <a href={`/blog/${post.id.replace(/\.(md|mdx)$/, '')}`}>{post.data.title}</a>
          </h2>
          <p class="card-desc">{post.data.description}</p>
          <div class="tags">
            {post.data.tags.map(tag => (
              <span class="tag" style={`background: ${getTagColor(tag).bg}; color: ${getTagColor(tag).text}`}>{tag}</span>
            ))}
          </div>
        </article>
      ))}
    </div>

    <div class="empty-state" id="emptyState" hidden>
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <circle cx="11" cy="11" r="8"/>
        <path d="M21 21l-4.35-4.35"/>
      </svg>
      <p>No articles found</p>
      <span>Try adjusting your search or filter</span>
    </div>
  </main>

  <Footer />

  <script>
    const tagButtons = document.querySelectorAll('.tag-filter-btn');
    const cards = document.querySelectorAll('.card');
    const searchInput = document.getElementById('searchInput') as HTMLInputElement;
    const emptyState = document.getElementById('emptyState') as HTMLElement;

    let activeTag = 'all';
    let searchQuery = '';

    // Unified filter — always applies both tag AND search
    function filterCards() {
      cards.forEach(card => {
        const tags = JSON.parse(card.getAttribute('data-tags') || '[]');
        const title = card.querySelector('.card-title')?.textContent?.toLowerCase() || '';
        const desc = card.querySelector('.card-desc')?.textContent?.toLowerCase() || '';
        const matchesTag = activeTag === 'all' || tags.includes(activeTag);
        const matchesSearch = searchQuery === '' ||
          title.includes(searchQuery) ||
          desc.includes(searchQuery);
        (card as HTMLElement).style.display = (matchesTag && matchesSearch) ? '' : 'none';
      });
      updateEmptyState();
    }

    // Reset search when tag changes
    tagButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        activeTag = btn.getAttribute('data-tag') || 'all';
        searchQuery = ''; // reset search on tag change
        if (searchInput) searchInput.value = '';
        tagButtons.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        filterCards();
      });
    });

    // Search within current tag
    searchInput?.addEventListener('input', () => {
      searchQuery = searchInput.value.toLowerCase();
      filterCards();
    });

    function updateEmptyState() {
      const visibleCards = Array.from(cards).filter(card =>
        (card as HTMLElement).style.display !== 'none'
      );
      if (emptyState) emptyState.hidden = visibleCards.length > 0;
    }

    // Card click navigation
    cards.forEach(card => {
      card.addEventListener('click', (e) => {
        const link = card.querySelector('.card-title a') as HTMLAnchorElement;
        if (link && !e.defaultPrevented) window.location.href = link.href;
      });
      card.style.cursor = 'pointer';
    });
  </script>
</Layout>

<style>
  :global(body) {
    font-family: var(--font-family);
    background: var(--color-bg-blog);
    color: var(--color-text-primary);
    min-height: 100dvh;
    margin: 0;
  }

  .main {
    position: relative;
    z-index: 1;
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
    padding: 7rem 2rem 3.125rem;
  }

  .header {
    text-align: center;
    margin-bottom: var(--space-8);
    opacity: 0;
    animation: fadeInUp 1s ease forwards 0.1s;
  }

  .header-title {
    font-size: clamp(1.75rem, 5vw, 2.75rem);
    font-weight: 600;
    line-height: var(--line-height-tight);
    letter-spacing: var(--letter-spacing-normal);
    color: var(--color-text-primary);
  }

  @keyframes fadeIn {
    to { opacity: 1; }
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(18px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .search-filter {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    margin-bottom: var(--space-8);
    opacity: 0;
    animation: fadeInUp 1s ease forwards 0.3s;
  }

  .tag-filters {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    justify-content: flex-start;
  }

  .tag-filter-btn {
    padding: var(--space-1) var(--space-4);
    font-family: var(--font-family);
    font-size: var(--font-size-sm);
    font-weight: 500;
    color: var(--color-text-secondary);
    background: transparent;
    border: 1px solid var(--tag-filter-border);
    border-radius: var(--radius-full);
    cursor: pointer;
    transition: all var(--duration-normal) var(--ease-out);
    white-space: nowrap;
  }

  .tag-filter-btn:hover {
    border-color: var(--color-primary);
    color: var(--color-text-link);
    background: var(--color-primary-alpha-08);
  }

  .tag-filter-btn:focus-visible {
    outline: 2px solid var(--color-text-link);
    outline-offset: 2px;
  }

  .tag-filter-btn.active {
    background: var(--color-primary-alpha-15);
    color: var(--color-text-link);
    border-color: var(--color-primary-alpha-30);
  }

  .search-box {
    position: relative;
    max-width: 400px;
    margin: 0 auto;
    width: 100%;
  }

  .search-input {
    width: 100%;
    padding: var(--space-3) var(--space-4) var(--space-3) 2.75rem;
    font-family: var(--font-family);
    font-size: var(--font-size-base);
    color: var(--color-text-primary);
    background: rgba(255, 255, 255, 0.55);
    border: 1px solid var(--color-primary-alpha-40);
    border-radius: var(--radius-full);
    outline: none;
    transition: all var(--duration-normal) var(--ease-out);
    box-sizing: border-box;
  }

  .search-input::placeholder {
    color: var(--color-text-tertiary);
  }

  .search-input:focus {
    background: rgba(255, 255, 255, 0.8);
    border-color: var(--color-primary-alpha-40);
    box-shadow: 0 0 0 3px var(--color-primary-alpha-08);
  }

  .search-icon {
    position: absolute;
    left: var(--space-4);
    top: 50%;
    transform: translateY(-50%);
    width: 18px;
    height: 18px;
    color: var(--color-text-tertiary);
    pointer-events: none;
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(var(--max-width-card), 1fr));
    gap: var(--space-6);
  }

  .card {
    position: relative;
    background: var(--glass-bg-light);
    backdrop-filter: var(--glass-blur-light);
    -webkit-backdrop-filter: var(--glass-blur-light);
    border: 1px solid var(--glass-border-light);
    border-radius: var(--radius-xl);
    padding: var(--space-6);
    cursor: pointer;
    transition: all var(--duration-slow) var(--ease-out);
    opacity: 0;
    animation: cardIn 0.8s ease forwards;
  }

  @keyframes cardIn {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .card:hover {
    background: rgba(255, 255, 255, 0.55);
    border-color: var(--glass-border-light-hover);
    transform: translateY(-4px);
    box-shadow: var(--shadow-card-hover);
  }

  .card:active {
    transform: scale(0.98);
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-3);
  }

  .card-date,
  .card-reading-time {
    font-size: var(--font-size-sm);
    color: var(--color-text-tertiary);
    letter-spacing: var(--letter-spacing-wider);
  }

  .card-dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--color-text-tertiary);
    opacity: 0.4;
  }

  .card-title {
    font-size: var(--font-size-xl);
    font-weight: 500;
    line-height: var(--line-height-normal);
    margin-bottom: var(--space-3);
    color: var(--color-text-primary);
    letter-spacing: var(--letter-spacing-normal);
    transition: color var(--duration-normal) var(--ease-out);
  }

  .card-title a {
    color: inherit;
    text-decoration: none;
  }

  .card-title a:focus-visible {
    outline: 2px solid var(--color-text-link);
    outline-offset: 2px;
    border-radius: 4px;
  }

  .card:hover .card-title a {
    color: var(--color-text-link);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .card-desc {
    font-size: var(--font-size-lg);
    line-height: var(--line-height-body);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-5);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    font-weight: 300;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .tag {
    font-size: var(--font-size-xs);
    font-weight: 500;
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    transition: all var(--duration-normal) var(--ease-out);
    letter-spacing: 0.02em;
  }

  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--space-12) var(--space-8);
    text-align: center;
    color: var(--color-text-tertiary);
    gap: var(--space-3);
  }

  .empty-state svg {
    opacity: 0.4;
    margin-bottom: var(--space-2);
  }

  .empty-state p {
    font-size: var(--font-size-xl);
    font-weight: 500;
    color: var(--color-text-secondary);
  }

  .empty-state span {
    font-size: var(--font-size-base);
  }

  .empty-state[hidden] {
    display: none;
  }

  @media (max-width: 768px) {
    .main { padding: 6rem 1.25rem 5rem; }
    .card-grid { grid-template-columns: 1fr; gap: var(--space-5); }
    .card { padding: var(--space-5); }
    .header-title { font-size: 1.5rem; }
    .search-filter { gap: var(--space-3); margin-bottom: var(--space-6); }
    .tag-filters { justify-content: flex-start; overflow-x: auto; scrollbar-width: none; -ms-overflow-style: none; }
    .tag-filters::-webkit-scrollbar { display: none; }
  }

  @media (max-width: 480px) {
    .main { padding: 5rem 1rem 4rem; }
    .card { padding: var(--space-4); border-radius: var(--radius-lg); }
    .card-title { font-size: var(--font-size-lg); }
    .card-desc { font-size: var(--font-size-base); }
    .search-input {
      padding: var(--space-3) var(--space-4) var(--space-3) 2.5rem;
      font-size: var(--font-size-sm);
    }
    .empty-state { padding: var(--space-10) var(--space-4); }
  }

  @media (prefers-reduced-motion: reduce) {
    .card, .header, .search-filter { animation: none; opacity: 1; }
  }
</style>
