---
import { getCollection } from 'astro:content';
import BlogNav from '../../components/BlogNav.astro';
import OrbBackground from '../../components/react/OrbBackground';
import ShinyText from '../../components/react/ShinyText';
import Footer from '../../components/Footer.astro';
import { getTagColor } from '../../utils/tagColors';
import '../../styles/global.css';
import '../../styles/tokens.css';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) =>
  b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const allTags = [...new Set(sortedPosts.flatMap(post => post.data.tags))];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Blog - Solozed</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <OrbBackground client:idle />
    <BlogNav currentPath="/blog" theme="light" />

    <main class="main">
      <header class="header">
        <h1 class="header-title">
          <ShinyText text="The Age of AI, the grace to be" speed={5} color="#1E293B" shineColor="#38D9D9" client:idle />
        </h1>
      </header>

      <div class="search-filter" role="search">
        <div class="search-box">
          <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"/>
            <path d="M21 21l-4.35-4.35"/>
          </svg>
          <input type="text" class="search-input" placeholder="Search articles..." id="searchInput" />
        </div>
        <div class="tag-filters">
          <button class="tag-filter-btn active" data-tag="all">All</button>
          {allTags.map(tag => (
            <button class="tag-filter-btn" data-tag={tag}>{tag}</button>
          ))}
        </div>
      </div>

      <div class="card-grid" id="cardGrid">
        {sortedPosts.map((post, index) => (
          <article class="card" data-tags={JSON.stringify(post.data.tags)} style={`animation-delay: ${0.4 + index * 0.1}s`}>
            <div class="card-meta">
              <time class="card-date">{post.data.pubDate.toISOString().split('T')[0]}</time>
              <span class="card-dot"></span>
              <span class="card-reading-time">{Math.ceil(post.body.replace(/\s/g, '').length / 400)} min</span>
            </div>
            <h2 class="card-title">
              <a href={`/blog/${post.id.replace(/\.(md|mdx)$/, '')}`}>{post.data.title}</a>
            </h2>
            <p class="card-desc">{post.data.description}</p>
            <div class="tags">
              {post.data.tags.map(tag => (
                <span class="tag" style={`background: ${getTagColor(tag).bg}; color: ${getTagColor(tag).text}`}>{tag}</span>
              ))}
            </div>
          </article>
        ))}
      </div>

      <div class="empty-state" id="emptyState" hidden>
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="11" cy="11" r="8"/>
          <path d="M21 21l-4.35-4.35"/>
        </svg>
        <p>No articles found</p>
        <span>Try adjusting your search or filter</span>
      </div>
    </main>

    <script>
      // Tag filter functionality
      const tagButtons = document.querySelectorAll('.tag-filter-btn');
      const cards = document.querySelectorAll('.card');
      let activeTag = 'all';

      tagButtons.forEach(btn => {
        btn.addEventListener('click', () => {
          activeTag = btn.getAttribute('data-tag') || 'all';
          tagButtons.forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          filterCards();
        });
      });

      function filterCards() {
        cards.forEach(card => {
          const tags = JSON.parse(card.getAttribute('data-tags') || '[]');
          const matchesTag = activeTag === 'all' || tags.includes(activeTag);
          (card as HTMLElement).style.display = matchesTag ? '' : 'none';
        });
        updateEmptyState();
      }

      // Search functionality
      const searchInput = document.getElementById('searchInput') as HTMLInputElement;
      const emptyState = document.getElementById('emptyState') as HTMLElement;
      searchInput?.addEventListener('input', () => {
        const query = searchInput.value.toLowerCase();
        cards.forEach(card => {
          const title = card.querySelector('.card-title')?.textContent?.toLowerCase() || '';
          const desc = card.querySelector('.card-desc')?.textContent?.toLowerCase() || '';
          const matches = title.includes(query) || desc.includes(query);
          (card as HTMLElement).style.display = matches ? '' : 'none';
        });
        updateEmptyState();
      });

      function updateEmptyState() {
        const visibleCards = Array.from(cards).filter(card =>
          (card as HTMLElement).style.display !== 'none'
        );
        if (emptyState) {
          emptyState.hidden = visibleCards.length > 0;
        }
      }

      // Card click navigation
      cards.forEach(card => {
        card.addEventListener('click', (e) => {
          const link = card.querySelector('.card-title a') as HTMLAnchorElement;
          if (link && !e.defaultPrevented) {
            window.location.href = link.href;
          }
        });
        card.style.cursor = 'pointer';
      });
    </script>
    <Footer />
  </body>
</html>

<style>
  :global(body) {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    background: #F5F8FA;
    color: #1E293B;
    min-height: 100vh;
    overflow-x: hidden;
    margin: 0;
  }

  .main {
    position: relative;
    z-index: 1;
    max-width: 1200px;
    margin: 0 auto;
    padding: 7rem 2rem 6rem;
  }

  .header {
    text-align: center;
    margin-bottom: 3rem;
    opacity: 0;
    animation: fadeInUp 1s ease forwards 0.1s;
  }

  .header-title {
    font-size: clamp(1.75rem, 5vw, 2.75rem);
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: 0.01em;
    color: #1E293B;
  }

  @keyframes fadeIn {
    to { opacity: 1; }
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(18px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .search-filter {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 3rem;
    opacity: 0;
    animation: fadeInUp 1s ease forwards 0.3s;
  }

  .search-box {
    position: relative;
    max-width: 400px;
    margin: 0 auto;
    width: 100%;
  }

  .search-input {
    width: 100%;
    padding: 0.875rem 1.25rem 0.875rem 3rem;
    font-family: inherit;
    font-size: 0.875rem;
    color: #1E293B;
    background: rgba(245, 248, 250, 0.85);
    border: 1px solid rgba(139, 158, 255, 0.15);
    border-radius: 9999px;
    outline: none;
    transition: all 0.3s ease;
    backdrop-filter: blur(12px);
    box-sizing: border-box;
  }

  .search-input::placeholder {
    color: #4F647A;
  }

  .search-input:focus {
    background: rgba(255, 255, 255, 0.7);
    border-color: rgba(56, 217, 217, 0.3);
    box-shadow: 0 0 0 3px rgba(56, 217, 217, 0.08);
  }

  .search-icon {
    position: absolute;
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    width: 18px;
    height: 18px;
    color: #94A3B8;
    pointer-events: none;
  }

  .tag-filters {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
  }

  .tag-filter-btn {
    padding: 0.4375rem 1rem;
    font-family: inherit;
    font-size: 0.6875rem;
    font-weight: 500;
    color: #475569;
    background: rgba(245, 248, 250, 0.85);
    border: 1px solid rgba(139, 158, 255, 0.15);
    border-radius: 9999px;
    cursor: pointer;
    transition: all 0.3s ease;
    backdrop-filter: blur(12px);
  }

  .tag-filter-btn:hover {
    background: rgba(255, 255, 255, 0.6);
    border-color: rgba(139, 158, 255, 0.2);
  }

  .tag-filter-btn:focus-visible {
    outline: 2px solid #0E7490;
    outline-offset: 2px;
  }

  .tag-filter-btn.active {
    background: rgba(56, 217, 217, 0.12);
    color: #0E7490;
    border-color: rgba(56, 217, 217, 0.25);
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.75rem;
  }

  .card {
    position: relative;
    background: rgba(255, 255, 255, 0.28);
    backdrop-filter: blur(32px);
    -webkit-backdrop-filter: blur(32px);
    border: 1px solid rgba(139, 158, 255, 0.08);
    border-radius: 20px;
    padding: 1.875rem;
    cursor: pointer;
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    opacity: 0;
    animation: cardIn 0.8s ease forwards;
  }

  @keyframes cardIn {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .card:hover {
    background: rgba(255, 255, 255, 0.5);
    border-color: rgba(56, 217, 217, 0.4);
    transform: translateY(-5px);
    box-shadow:
      0 0 0 1px rgba(56, 217, 217, 0.15),
      0 0 20px rgba(56, 217, 217, 0.08),
      0 0 40px rgba(56, 217, 217, 0.04),
      0 16px 32px rgba(56, 217, 217, 0.06),
      0 6px 12px rgba(0, 0, 0, 0.02);
  }

  .card:active {
    transform: scale(0.98);
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    margin-bottom: 1.125rem;
  }

  .card-date {
    font-size: 0.6875rem;
    color: #94A3B8;
    letter-spacing: 0.03em;
  }

  .card-dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: #94A3B8;
    opacity: 0.4;
  }

  .card-reading-time {
    font-size: 0.6875rem;
    color: #94A3B8;
  }

  .card-title {
    font-size: 1.125rem;
    font-weight: 500;
    line-height: 1.55;
    margin-bottom: 0.75rem;
    color: #1E293B;
    letter-spacing: -0.01em;
    transition: color 0.35s ease;
  }

  .card-title a {
    color: inherit;
    text-decoration: none;
  }

  .card-title a:focus-visible {
    outline: 2px solid #0E7490;
    outline-offset: 2px;
    border-radius: 4px;
  }

  .card:hover .card-title {
    color: #0E7490;
  }

  .card-desc {
    font-size: 1.0625rem;
    line-height: 2.0;
    color: #475569;
    margin-bottom: 1.5rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    font-weight: 300;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    font-size: 0.625rem;
    font-weight: 500;
    padding: 0.375rem 0.875rem;
    border-radius: 9999px;
    transition: all 0.3s ease;
  }

  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 4rem 2rem;
    text-align: center;
    color: #94A3B8;
    gap: 0.75rem;
  }

  .empty-state svg {
    opacity: 0.4;
    margin-bottom: 0.5rem;
  }

  .empty-state p {
    font-size: 1.125rem;
    font-weight: 500;
    color: #475569;
  }

  .empty-state span {
    font-size: 0.875rem;
  }

  .empty-state[hidden] {
    display: none;
  }

  @media (max-width: 768px) {
    .card-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .main {
      padding: 6rem 1.25rem 5rem;
    }

    .search-filter {
      gap: 0.875rem;
      margin-bottom: 2.5rem;
    }

    .card {
      padding: 1.5rem;
    }

    .header-title {
      font-size: 1.5rem;
    }
  }

  @media (max-width: 480px) {
    .main {
      padding: 5rem 1rem 4rem;
    }

    .card {
      padding: 1.25rem;
      border-radius: 16px;
    }

    .card-title {
      font-size: 1rem;
    }

    .card-desc {
      font-size: 0.9375rem;
      -webkit-line-clamp: 2;
    }

    .search-input {
      padding: 0.75rem 1rem 0.75rem 2.5rem;
      font-size: 0.8125rem;
    }

    .tag-filter-btn {
      padding: 0.375rem 0.75rem;
      font-size: 0.625rem;
    }

    .empty-state {
      padding: 3rem 1rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .header,
    .search-filter,
    .card {
      animation: none;
      opacity: 1;
    }

    .card:hover {
      transform: none;
    }

    .search-input,
    .tag-filter-btn,
    .tag,
    .card,
    .card-title {
      transition: none;
    }
  }
</style>
