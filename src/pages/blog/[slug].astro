---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import BlogNav from '../../components/BlogNav.astro';
import OrbBackground from '../../components/react/OrbBackground';
import Footer from '../../components/Footer.astro';
import { getTagColor } from '../../utils/tagColors';
import { readingTime } from '../../utils/readingTime';
import ArrowLeft from '../../components/react/ArrowLeft';
import ArrowRight from '../../components/react/ArrowRight';
import '../../styles/global.css';
import '../../styles/tokens.css';

const siteUrl = Astro.site?.toString() ?? '';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const sorted = posts.sort((a, b) =>
    b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
  );
  return sorted.map((post, i) => ({
    params: { slug: post.id.replace(/\.(md|mdx)$/, '',) },
    props: { post, prev: sorted[i + 1] ?? null, next: sorted[i - 1] ?? null },
  }));
}

const { post, prev, next } = Astro.props;
const { Content } = await render(post);

const slug = post.id.replace(/\.(md|mdx)$/, '');
const canonicalUrl = `${siteUrl}/blog/${slug}`;
const image = post.data.image ?? '/og-default.svg';

const timeToRead = readingTime(post.body);

// Approximate word count for schema: Chinese chars + English words
const rawBody = post.body
  .replace(/```[\s\S]*?```/g, '')
  .replace(/`[^`]*`/g, '')
  .replace(/!\[.*?\]\(.*?\)/g, '')
  .replace(/\[.*?\]\(.*?\)/g, '')
  .replace(/[#*_~>\-|]/g, '')
  .replace(/<[^>]+>/g, '');
const chineseChars = (rawBody.match(/[\u4e00-\u9fff]/g) || []).length;
const englishWords = rawBody
  .replace(/[\u4e00-\u9fff]/g, ' ')
  .split(/\s+/)
  .filter(w => w.length > 0).length;
const wordCount = chineseChars + englishWords;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": post.data.title,
  "description": post.data.description,
  "datePublished": post.data.pubDate.toISOString(),
  "dateModified": (post.data.updatedDate ?? post.data.pubDate).toISOString(),
  "wordCount": wordCount,
  "timeToRead": timeToRead,
  "url": canonicalUrl,
  "author": {
    "@type": "Person",
    "name": "solozed",
    "url": siteUrl
  },
  "publisher": {
    "@type": "Organization",
    "name": "solozed",
    "url": siteUrl,
    "logo": {
      "@type": "ImageObject",
      "url": `${siteUrl}/favicon.svg`
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": canonicalUrl
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": siteUrl
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Blog",
      "item": `${siteUrl}/blog`
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": post.data.title,
      "item": canonicalUrl
    }
  ]
};
---

<Layout
  title={`${post.data.title} - Solozed`}
  description={post.data.description}
  pathname={`/blog/${slug}`}
  image={image}
>
  <Fragment slot="head">
    <meta property="og:type" content="article" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="article:published_time" content={post.data.pubDate.toISOString()} />
    {post.data.updatedDate && (
      <meta property="article:modified_time" content={post.data.updatedDate.toISOString()} />
    )}
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <OrbBackground client:idle />
  <BlogNav currentPath="/blog" theme="light" />

  <main class="main">
    <article class="article">
      <header class="article-header">
        <a href="/blog" class="back-link">
          <ArrowLeft />
          Back to Blog
        </a>
        <div class="article-meta">
          <time class="article-date">{post.data.pubDate.toISOString().split('T')[0]}</time>
          <span class="article-dot"></span>
          <span class="article-reading-time">{timeToRead} min read</span>
          {post.data.updatedDate && (
            <>
              <span class="article-dot"></span>
              <span class="article-updated">Updated {post.data.updatedDate.toISOString().split('T')[0]}</span>
            </>
          )}
        </div>
        <h1 class="article-title">{post.data.title}</h1>
        <div class="tags">
          {post.data.tags.map(tag => (
            <span class="tag" style={`background: ${getTagColor(tag).bg}; color: ${getTagColor(tag).text}`}>{tag}</span>
          ))}
        </div>
      </header>

      <div class="article-content">
        <Content />
        <script>
          // Wrap each pre with a copy button
          document.querySelectorAll('.article-content pre').forEach(pre => {
            const wrapper = document.createElement('div');
            wrapper.className = 'code-block-wrapper';
            pre.parentNode.insertBefore(wrapper, pre);
            wrapper.appendChild(pre);

            const btn = document.createElement('button');
            btn.className = 'copy-btn';
            btn.textContent = 'Copy';
            btn.setAttribute('aria-label', 'Copy code');
            wrapper.appendChild(btn);

            btn.addEventListener('click', async () => {
              const code = pre.querySelector('code');
              const text = code ? code.textContent : pre.textContent;
              try {
                await navigator.clipboard.writeText(text);
                btn.textContent = 'Copied!';
                btn.classList.add('copied');
                setTimeout(() => {
                  btn.textContent = 'Copy';
                  btn.classList.remove('copied');
                }, 2000);
              } catch {
                btn.textContent = 'Failed';
                setTimeout(() => {
                  btn.textContent = 'Copy';
                }, 2000);
              }
            });
          });

          document.querySelectorAll('.article-content a[href]').forEach(link => {
            link.setAttribute('target', '_blank');
            link.setAttribute('rel', 'noopener noreferrer');
          });
        </script>
      </div>

      <footer class="article-footer">
        {(prev || next) && (
          <nav class="article-nav" aria-label="Article navigation">
            <div class="nav-prev">
              {prev && (
                <a href={`/blog/${prev.id.replace(/\.(md|mdx)$/, '')}`} class="nav-link">
                  <span class="nav-label"><ArrowLeft /> Previous</span>
                  <span class="nav-title">{prev.data.title}</span>
                </a>
              )}
            </div>
            <div class="nav-next">
              {next && (
                <a href={`/blog/${next.id.replace(/\.(md|mdx)$/, '')}`} class="nav-link">
                  <span class="nav-label">Next <ArrowRight /></span>
                  <span class="nav-title">{next.data.title}</span>
                </a>
              )}
            </div>
          </nav>
        )}
        <a href="/blog" class="back-link">
          <ArrowLeft />
          Back to Blog
        </a>
      </footer>
    </article>
  </main>

  <Footer />
</Layout>

<style>
  :global(body) {
    font-family: var(--font-family);
    background: var(--color-bg-blog);
    color: var(--color-text-primary);
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    margin: 0;
  }

  :global(html) {
    overflow-x: auto;
  }

  .main {
    position: relative;
    z-index: 1;
    flex: 1;
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
    padding: 7rem 2rem 3.125rem;
  }

  /* --- Article card --- */
  .article {
    background: rgba(255, 255, 255, 0.45);
    backdrop-filter: var(--glass-blur-light);
    -webkit-backdrop-filter: var(--glass-blur-light);
    border: 1px solid var(--glass-border-light);
    border-radius: var(--radius-2xl);
    padding: var(--space-8);
    animation: fadeInUp 0.8s ease forwards;
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* --- Article header --- */
  .article-header {
    margin-bottom: var(--space-8);
    padding-bottom: var(--space-6);
    border-bottom: 1px solid rgba(139, 158, 255, 0.12);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--font-size-sm);
    color: var(--color-text-tertiary);
    text-decoration: none;
    margin-bottom: var(--space-5);
    transition: color var(--duration-normal) var(--ease-out);
  }

  .back-link:hover { color: var(--color-primary); }

  .back-link:focus-visible {
    outline: 2px solid var(--color-text-link);
    outline-offset: 2px;
    border-radius: 4px;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-bottom: var(--space-4);
    flex-wrap: wrap;
  }

  .article-date {
    font-size: var(--font-size-sm);
    color: var(--color-text-tertiary);
    letter-spacing: var(--letter-spacing-wider);
  }

  .article-dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--color-text-tertiary);
    opacity: 0.5;
  }

  .article-reading-time,
  .article-updated {
    font-size: var(--font-size-sm);
    color: var(--color-text-tertiary);
    letter-spacing: var(--letter-spacing-wider);
  }

  .article-updated {
    color: var(--color-text-link);
  }

  .article-title {
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 400;
    line-height: var(--line-height-tight);
    color: var(--color-text-primary);
    margin-bottom: var(--space-5);
    letter-spacing: var(--letter-spacing-normal);
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .tag {
    font-size: var(--font-size-xs);
    font-weight: 500;
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    letter-spacing: 0.02em;
  }

  /* --- Article body typography --- */
  .article-content {
    font-size: var(--font-size-lg);
    line-height: var(--line-height-body);
    color: var(--color-text-secondary);
  }

  .article-content :global(h2) {
    font-size: 1.375rem;
    font-weight: 500;
    color: var(--color-text-primary);
    margin-top: var(--space-10);
    margin-bottom: var(--space-4);
    padding-left: var(--space-4);
    border-left: 4px solid rgba(56, 217, 217, 0.55);
    line-height: var(--line-height-tight);
  }

  .article-content :global(h3) {
    font-size: var(--font-size-xl);
    font-weight: 500;
    color: var(--color-text-primary);
    margin-top: var(--space-8);
    margin-bottom: var(--space-3);
    padding-left: var(--space-3);
    border-left: 2px solid var(--color-primary-alpha-25);
    line-height: var(--line-height-tight);
  }

  .article-content :global(p) {
    margin-bottom: var(--space-5);
  }

  .article-content :global(strong) {
    color: var(--color-accent-bold);
    font-weight: 600;
  }

  .article-content :global(a) {
    color: var(--color-text-link);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color var(--duration-normal) var(--ease-out);
  }

  .article-content :global(a:hover) {
    border-bottom-color: var(--color-text-link);
  }

  .article-content :global(a:focus-visible) {
    outline: 2px solid var(--color-text-link);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .article-content :global(ul),
  .article-content :global(ol) {
    margin-bottom: var(--space-5);
    padding-left: var(--space-6);
  }

  .article-content :global(li) {
    margin-bottom: var(--space-2);
  }

  .article-content :global(code) {
    font-family: var(--font-family-mono);
    font-size: 0.875em;
    background: var(--color-primary-alpha-08);
    padding: 0.2em 0.4em;
    border-radius: var(--radius-sm);
    color: var(--color-text-link);
  }

  .article-content :global(pre) {
    background: rgba(30, 41, 59, 0.92);
    padding: var(--space-5);
    border-radius: var(--radius-lg);
    overflow-x: auto;
    margin-bottom: var(--space-5);
    border: 1px solid rgba(255, 255, 255, 0.06);
  }

  .article-content :global(pre code) {
    background: none;
    padding: 0;
    color: #CBD5E1;
    font-family: var(--font-family-mono);
    font-size: var(--font-size-sm);
    line-height: 1.7;
  }

  /* --- Code block wrapper + copy button --- */
  .article-content :global(.code-block-wrapper) {
    position: relative;
  }

  .article-content :global(.copy-btn) {
    position: absolute;
    top: var(--space-3);
    right: var(--space-3);
    padding: var(--space-1) var(--space-3);
    font-family: var(--font-family);
    font-size: var(--font-size-xs);
    font-weight: 500;
    color: rgba(255, 255, 255, 0.7);
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: all var(--duration-normal) var(--ease-out);
    letter-spacing: 0.03em;
  }

  .article-content :global(.copy-btn:hover) {
    color: #fff;
    background: rgba(56, 217, 217, 0.15);
    border-color: rgba(56, 217, 217, 0.3);
  }

  .article-content :global(.copy-btn.copied) {
    color: #38D9D9;
    border-color: rgba(56, 217, 217, 0.4);
    background: rgba(56, 217, 217, 0.08);
  }

  .article-content :global(blockquote) {
    border-left: 3px solid var(--color-primary);
    background: var(--color-primary-alpha-08);
    padding: var(--space-3) var(--space-5);
    margin: var(--space-5) 0;
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    font-style: italic;
    color: var(--color-text-secondary);
  }

  /* --- Table (Markdown) --- */
  .article-content :global(table) {
    width: auto;
    min-width: 100%;
    border-collapse: collapse;
    margin-bottom: var(--space-5);
    font-size: var(--font-size-base);
    background: rgba(255, 255, 255, 0.35);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-primary-alpha-25);
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .article-content :global(thead) {
    background: var(--color-primary-alpha-08);
  }

  .article-content :global(th) {
    text-align: left;
    font-weight: 700;
    font-size: var(--font-size-base);
    color: var(--color-text-primary);
    padding: var(--space-3) var(--space-4);
    border-bottom: 1px solid var(--color-primary-alpha-25);
    white-space: nowrap;
    letter-spacing: var(--letter-spacing-wide);
    text-transform: uppercase;
  }

  .article-content :global(td) {
    padding: var(--space-3) var(--space-4);
    border-bottom: 1px solid var(--color-primary-alpha-08);
    color: var(--color-text-secondary);
    vertical-align: top;
  }

  .article-content :global(tr:last-child td) {
    border-bottom: none;
  }

  .article-content :global(tbody tr:hover) {
    background: var(--color-primary-alpha-08);
  }

  /* --- Article footer --- */
  .article-footer {
    margin-top: var(--space-10);
    padding-top: var(--space-6);
    border-top: 1px solid rgba(139, 158, 255, 0.12);
  }

  /* --- Prev/Next navigation --- */
  .article-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
    align-items: stretch;
  }

  .nav-prev { grid-column: 1; height: 100%; }
  .nav-next { grid-column: 2; height: 100%; text-align: right; }

  .nav-link {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-2);
    height: 100%;
    text-decoration: none;
    padding: var(--space-4);
    border-radius: var(--radius-lg);
    background: rgba(255, 255, 255, 0.4);
    border: 1px solid rgba(139, 158, 255, 0.1);
    transition: all var(--duration-normal) var(--ease-out);
  }

  .nav-link:hover {
    background: rgba(255, 255, 255, 0.6);
    border-color: var(--glass-border-light-hover);
  }

  .nav-label {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--font-size-xs);
    font-weight: 500;
    color: var(--color-text-tertiary);
    letter-spacing: var(--letter-spacing-wider);
    text-transform: uppercase;
  }

  .nav-title {
    font-size: var(--font-size-base);
    font-weight: 500;
    color: var(--color-text-primary);
    line-height: var(--line-height-normal);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* --- Responsive --- */
  @media (max-width: 768px) {
    .main { padding: 6rem 1.25rem 3.125rem; }
    .article { padding: var(--space-5); border-radius: var(--radius-xl); }
    .article-nav { grid-template-columns: 1fr 1fr; }
    .nav-next { grid-column: 2; text-align: right; }
  }

  @media (max-width: 480px) {
    .main { padding: 5rem 1rem 3.125rem; }
    .article { padding: var(--space-4); border-radius: var(--radius-lg); }
    .article-title { font-size: 1.375rem; }
    .article-content { font-size: var(--font-size-base); }
    .article-content :global(pre) { padding: var(--space-4); }
    .article-nav { gap: var(--space-3); }
    .nav-link { padding: var(--space-3); }
  }

  @media (prefers-reduced-motion: reduce) {
    .article { animation: none; opacity: 1; }
    .article-content :global(a),
    .article-content :global(code),
    .back-link, .nav-link {
      transition: none;
    }
  }
</style>
