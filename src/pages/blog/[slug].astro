---
import { getCollection, render } from 'astro:content';
import BlogNav from '../../components/BlogNav.astro';
import OrbBackground from '../../components/react/OrbBackground';
import Footer from '../../components/Footer.astro';
import '../../styles/global.css';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

function getTagColor(tag: string) {
  const colors = [
    { bg: 'rgba(139, 92, 246, 0.07)', text: '#7C3AED' },
    { bg: 'rgba(56, 189, 248, 0.07)', text: '#0284C7' },
    { bg: 'rgba(59, 130, 246, 0.07)', text: '#2563EB' },
    { bg: 'rgba(239, 68, 68, 0.07)', text: '#DC2626' },
    { bg: 'rgba(34, 197, 94, 0.07)', text: '#16A34A' },
    { bg: 'rgba(251, 191, 36, 0.07)', text: '#D97706' },
    { bg: 'rgba(236, 72, 153, 0.07)', text: '#DB2777' },
  ];
  let hash = 0;
  for (let i = 0; i < tag.length; i++) {
    hash = tag.charCodeAt(i) + ((hash << 5) - hash);
  }
  return colors[Math.abs(hash) % colors.length];
}
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{post.data.title} - Solozed</title>
    <meta name="description" content={post.data.description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <OrbBackground client:load />
    <BlogNav currentPath="/blog" theme="light" />

    <main class="main">
      <article class="article">
        <header class="article-header">
          <a href="/blog" class="back-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M19 12H5M12 19l-7-7 7-7"/>
            </svg>
            Back to Blog
          </a>
          <div class="article-meta">
            <time class="article-date">{post.data.pubDate.toISOString().split('T')[0]}</time>
          </div>
          <h1 class="article-title">{post.data.title}</h1>
          <div class="tags">
            {post.data.tags.map(tag => (
              <span class="tag" style={`background: ${getTagColor(tag).bg}; color: ${getTagColor(tag).text}`}>{tag}</span>
            ))}
          </div>
        </header>

        <div class="article-content">
          <Content />
        </div>

        <footer class="article-footer">
          <a href="/blog" class="back-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M19 12H5M12 19l-7-7 7-7"/>
            </svg>
            Back to Blog
          </a>
        </footer>
      </article>
    </main>
    <Footer />
  </body>
</html>

<style>
  :global(body) {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    background: #F5F8FA;
    color: #1E293B;
    min-height: 100vh;
    margin: 0;
    display: flex;
    flex-direction: column;
  }

  :global(html) {
    overflow-x: auto;
  }

  .main {
    position: relative;
    z-index: 1;
    max-width: 1200px;
    margin: 0 auto;
    padding: 7rem 2rem 6rem;
    flex: 1;
  }

  .article {
    background: rgba(255, 255, 255, 0.4);
    backdrop-filter: blur(32px);
    -webkit-backdrop-filter: blur(32px);
    border: 1px solid rgba(139, 158, 255, 0.08);
    border-radius: 24px;
    padding: 2.5rem;
    animation: fadeInUp 0.8s ease forwards;
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .article-header {
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(139, 158, 255, 0.1);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: #94A3B8;
    text-decoration: none;
    margin-bottom: 1.5rem;
    transition: color 0.3s ease;
  }

  .back-link:hover {
    color: #38D9D9;
  }

  .back-link:focus-visible {
    outline: 2px solid #0E7490;
    outline-offset: 2px;
    border-radius: 4px;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .article-date {
    font-size: 0.8125rem;
    color: #94A3B8;
  }

  .article-title {
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 400;
    line-height: 1.3;
    color: #1E293B;
    margin-bottom: 1.25rem;
    letter-spacing: -0.01em;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    font-size: 0.625rem;
    font-weight: 500;
    padding: 0.375rem 0.875rem;
    border-radius: 9999px;
  }

  .article-content {
    font-size: 1.0625rem;
    line-height: 2.0;
    color: #475569;
  }

  .article-content :global(h2) {
    font-size: 1.375rem;
    font-weight: 500;
    color: #1E293B;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    border-left: 3px solid #38D9D9;
    padding-left: 0.75rem;
  }

  .article-content :global(h3) {
    font-size: 1.125rem;
    font-weight: 500;
    color: #1E293B;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    border-left: 2px solid rgba(56, 217, 217, 0.4);
    padding-left: 0.625rem;
  }

  .article-content :global(p) {
    margin-bottom: 1.5rem;
  }

  .article-content :global(strong) {
    color: #F29719;
    font-weight: 600;
  }

  .article-content :global(a) {
    color: #0E7490;
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.3s ease;
  }

  .article-content :global(a:hover) {
    border-bottom-color: #0E7490;
  }

  .article-content :global(a:focus-visible) {
    outline: 2px solid #0E7490;
    outline-offset: 2px;
    border-radius: 2px;
  }

  .article-content :global(ul),
  .article-content :global(ol) {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }

  .article-content :global(li) {
    margin-bottom: 0.5rem;
  }

  .article-content :global(code) {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.875em;
    background: rgba(56, 217, 217, 0.08);
    padding: 0.2em 0.4em;
    border-radius: 4px;
    color: #0E7490;
  }

  .article-content :global(pre) {
    background: rgba(30, 41, 59, 0.9);
    padding: 1.25rem;
    border-radius: 12px;
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }

  .article-content :global(pre code) {
    background: none;
    padding: 0;
    color: #E2E8F0;
    font-size: 0.8125rem;
    line-height: 1.7;
  }

  .article-content :global(blockquote) {
    border-left: 3px solid #38D9D9;
    background: rgba(56, 217, 217, 0.04);
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    padding: 0.75rem 1.25rem;
    border-radius: 0 8px 8px 0;
    font-style: italic;
    color: #64748B;
  }

  .article-footer {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(139, 158, 255, 0.1);
  }

  @media (max-width: 768px) {
    .main {
      padding: 6rem 1.25rem 5rem;
    }

    .article {
      padding: 1.5rem;
      border-radius: 20px;
    }
  }
</style>
